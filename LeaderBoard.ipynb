import pandas as pd
import os

# ===============================
# Step 1: New Results (after model eval)
# ===============================

new_results = pd.DataFrame({
    "Model": ["Logistic Regression", "SVM", "Random Forest"],
    "Accuracy": [acc_lr, acc_svm, acc_rf],
    "Precision": [prec_lr, prec_svm, prec_rf],
    "Recall": [rec_lr, rec_svm, rec_rf],
    "F1 Score": [f1_lr, f1_svm, f1_rf]
})

# ===============================
# Step 2: Load Existing Leaderboard
# ===============================

file_path = "leaderboard/leaderboard.csv"

if os.path.exists(file_path):
    old_lb = pd.read_csv(file_path)

    # Remove old entries of same models (to avoid duplicates)
    old_lb = old_lb[~old_lb["Model"].isin(new_results["Model"])]

    lb = pd.concat([old_lb, new_results], ignore_index=True)
else:
    lb = new_results

# ===============================
# Step 3: Sort + Rank
# ===============================

lb = lb.sort_values(by="Accuracy", ascending=False)
lb.reset_index(drop=True, inplace=True)
lb["Rank"] = lb.index + 1

# ===============================
# Step 4: Save (IMPORTANT 🔥)
# ===============================

os.makedirs("leaderboard", exist_ok=True)
lb.to_csv(file_path, index=False)

# ===============================
# Step 5: Display
# ===============================

print("\n🏆 Updated Leaderboard:\n")
print(lb)
}
